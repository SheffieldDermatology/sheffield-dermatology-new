{
  "name": "sheffield-dermatology-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Sheffield Dermatology — integrated public website, booking, patient portal and staff workspace",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "jobs:run": "tsx scripts/run-jobs.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:server": "rm -rf var/dev-db && mkdir -p var/dev-db var/storage && npm run db:migrate && npm run db:seed && next dev -p 3100",
    "audit:deps": "npm audit --omit=dev"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.10",
    "otplib": "^13.4.1",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.0",
    "eslint-config-next": "16.2.10",
    "tsx": "^4.23.1",
    "typescript": "^5.9.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
