# Sheffield Dermatology platform — environment configuration
# Copy to .env for local development. NEVER commit real values.
# In production every secret must be set in the deployment platform's
# secret manager, not in a file.

# ── Core ────────────────────────────────────────────────────────────────
# development | test | production (NODE_ENV is set by the tooling)
# Public origin of the deployment, used for absolute links in emails/sitemap.
APP_ORIGIN=http://localhost:3000

# 32+ char random secret for session-token HMAC and CSRF tokens.
# Generate with: openssl rand -base64 48
SESSION_SECRET=

# ── Database ────────────────────────────────────────────────────────────
# Production/staging: managed PostgreSQL connection string (UK region).
# Leave unset in development to use the embedded PGlite database in var/dev-db.
# DATABASE_URL=postgres://user:pass@host:5432/sheffield_dermatology

# ── Semble (clinical system of record) ─────────────────────────────────
# Obtain from Semble account management. Without these the booking system
# runs in request-only mode and no clinical data is exchanged.
# SEMBLE_API_URL=
# SEMBLE_API_TOKEN=
# SEMBLE_WEBHOOK_SECRET=

# ── Heidi AI scribe ────────────────────────────────────────────────────
# Prefer the supported Semble-linked integration. Without these the scribe
# workflow runs consent-first but transcription is marked "not connected".
# HEIDI_API_URL=
# HEIDI_API_KEY=

# ── Payments ───────────────────────────────────────────────────────────
# PAYMENT_PROVIDER=stripe | semble_pay
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PUBLISHABLE_KEY=

# ── Email (transactional) ──────────────────────────────────────────────
# Without these, messages are captured in the in-app outbox and not sent.
# EMAIL_PROVIDER=resend
# EMAIL_API_KEY=
# EMAIL_FROM="Sheffield Dermatology <no-reply@sheffielddermatology.com>"

# ── SMS (optional reminders) ───────────────────────────────────────────
# SMS_PROVIDER=twilio
# SMS_ACCOUNT_SID=
# SMS_AUTH_TOKEN=
# SMS_FROM=

# ── Team file storage ──────────────────────────────────────────────────
# STORAGE_PROVIDER=local | microsoft-graph | s3
# Local dev files are stored server-side under var/storage (encrypted).
# MS_GRAPH_TENANT_ID=
# MS_GRAPH_CLIENT_ID=
# MS_GRAPH_CLIENT_SECRET=
# S3_ENDPOINT=
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# ── Error monitoring (optional) ────────────────────────────────────────
# SENTRY_DSN=
